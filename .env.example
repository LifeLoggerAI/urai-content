# URAI Content package/runtime environment template
# Copy into the consuming Firebase/Next runtime app. Do not commit real secrets.
# Production launch requires provider-backed Firebase/Auth/Firestore/Storage/DNS/SSL/monitoring/rollback evidence.

NEXT_PUBLIC_SITE_URL=https://www.uraicontent.com
NEXT_PUBLIC_URAI_APP_URL=https://urai.app
NEXT_PUBLIC_URAI_STUDIO_URL=https://studio.urai.app
NEXT_PUBLIC_URAI_ADMIN_URL=https://admin.urai.app
NEXT_PUBLIC_GITHUB_ISSUES_URL=https://github.com/LifeLoggerAI/urai-content/issues
NEXT_PUBLIC_CI_RUN_URL=

# Firebase public client config for consuming web app.
# Public values are not secrets, but they must match the deployed Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin / CI deployment secrets.
# Configure these only in secret manager, hosting provider env, or CI protected secrets.
# Never expose these to the browser or commit real values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_HOSTING_SITE=www-uraicontent
URAI_CONTENT_ADMIN_UIDS=

# Admin seeding automation.
# Configure only in protected runtime/CI secret storage. Minimum 16 characters.
URAI_CONTENT_SEED_TOKEN=

# Server auth guard behavior.
# Header auth is convenient for local tests and trusted internal infra only.
# It is denied by default in production unless explicitly set to 1; do not enable on public production traffic unless a trusted proxy strips spoofed headers.
URAI_ENABLE_HEADER_AUTH=0

# Canonical Firestore collections used by runtime code and rules.
# userContentEntitlements is canonical; userEntitlements is a legacy denied alias and must be migrated before launch if old data exists.
URAI_CONTENT_ENTITLEMENTS_COLLECTION=userContentEntitlements

# Stripe - required only when paid tiers and marketplace checkout are enabled.
# Keep payment surfaces gated/disabled until checkout, webhook signature validation, entitlement writes, and provider evidence are verified.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_LICENSING_PARTNER=

# Optional observability.
# Production launch requires uptime, error monitoring, alert routing, release SHA visibility, and rollback smoke proof.
SENTRY_DSN=
