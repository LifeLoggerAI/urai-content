# URAI Content package/runtime environment template
# Copy into the consuming Firebase/Next runtime app. Do not commit real secrets.

NEXT_PUBLIC_SITE_URL=https://www.uraicontent.com
NEXT_PUBLIC_URAI_APP_URL=https://urai.app
NEXT_PUBLIC_URAI_STUDIO_URL=https://studio.urai.app
NEXT_PUBLIC_URAI_ADMIN_URL=https://admin.urai.app
NEXT_PUBLIC_GITHUB_ISSUES_URL=https://github.com/LifeLoggerAI/urai-content/issues
NEXT_PUBLIC_CI_RUN_URL=

# Firebase public client config for consuming web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin / CI deployment secrets - configure in secret manager or CI only
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_HOSTING_SITE=www-uraicontent
URAI_CONTENT_ADMIN_UIDS=

# Admin seeding automation. Configure only in protected runtime/CI secret storage.
URAI_CONTENT_SEED_TOKEN=

# Stripe - required only when paid tiers and marketplace checkout are enabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_LICENSING_PARTNER=

# Optional observability
SENTRY_DSN=