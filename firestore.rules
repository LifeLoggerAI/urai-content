rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (request.auth.token.roles is list && request.auth.token.roles.hasAny([role]))
      );
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('internalAdmin');
    }

    function isCreator() {
      return hasRole('creator') || hasRole('studio') || isAdmin();
    }

    function isPublishedPublic() {
      return resource.data.status == 'published' &&
        (resource.data.visibility == 'public' || resource.data.publicVisibility == 'public');
    }

    function isOwner(fieldName) {
      return signedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function isCreateOwner(fieldName) {
      return signedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    match /contentItems/{id} {
      allow read: if isPublishedPublic() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /contentPacks/{id} {
      allow read: if isPublishedPublic() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /marketplaceItems/{id} {
      allow read: if isPublishedPublic() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /creatorSubmissions/{id} {
      allow read: if isAdmin() || isOwner('creatorId');
      allow create: if isCreator() && isCreateOwner('creatorId');
      allow update, delete: if isAdmin();
    }

    match /exportJobs/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow create: if isCreateOwner('userId');
      allow update, delete: if isAdmin();
    }

    // Canonical entitlement collection used by runtime code: userContentEntitlements.
    match /userContentEntitlements/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow write: if isAdmin();
    }

    // Legacy alias retained as deny-by-default to prevent silent writes to the old name.
    // If old documents exist, migrate them into userContentEntitlements before launch.
    match /userEntitlements/{id} {
      allow read, write: if false;
    }

    match /contentLicenses/{id} {
      allow read: if isAdmin() || isOwner('licenseeId');
      allow write: if isAdmin();
    }

    match /consentRecords/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow create: if isCreateOwner('userId');
      allow update: if isAdmin() || isOwner('userId');
      allow delete: if isAdmin();
    }

    match /provenanceRecords/{id} {
      allow read, write: if isAdmin();
    }

    match /analyticsEvents/{id} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /tierConfigs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roadmapPhases/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /expansionModules/{id} {
      allow read: if resource.data.publicVisibility == 'public' || isAdmin();
      allow write: if isAdmin();
    }

    match /systemIntegrations/{id} {
      allow read, write: if isAdmin();
    }

    match /seoPages/{id} {
      allow read: if (resource.data.status == 'published' && resource.data.noIndex == false) || isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
