rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (request.auth.token.roles is list && request.auth.token.roles.hasAny([role]))
      );
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('internalAdmin');
    }

    function isCreator() {
      return hasRole('creator') || hasRole('studio') || isAdmin();
    }

    function isPublicContentItem() {
      return resource.data.status == 'published' && resource.data.visibility == 'public';
    }

    function isPublishedContentPack() {
      return resource.data.status == 'published'
        && resource.data.tierVisibility is list
        && resource.data.tierVisibility.size() > 0;
    }

    function isApprovedMarketplaceItem() {
      return resource.data.moderationStatus == 'approved'
        && resource.data.tier in ['free', 'pro', 'paid'];
    }

    function isOwner(fieldName) {
      return signedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function isCreateOwner(fieldName) {
      return signedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    function validAnalyticsCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'event',
          'userId',
          'entityId',
          'timestamp',
          'metadata'
        ])
        && request.resource.data.event in [
          'content_viewed',
          'ritual_previewed',
          'ritual_added',
          'story_template_selected',
          'export_template_used',
          'marketplace_item_viewed',
          'marketplace_item_unlocked',
          'admin_content_published',
          'moderation_decision_saved'
        ]
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.entityId is string
        && request.resource.data.entityId.size() > 0
        && request.resource.data.entityId.size() <= 160
        && request.resource.data.timestamp is string
        && request.resource.data.timestamp.size() <= 64
        && request.resource.data.metadata is map;
    }

    match /contentItems/{id} {
      allow read: if isPublicContentItem() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /contentPacks/{id} {
      allow read: if isPublishedContentPack() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /marketplaceItems/{id} {
      allow read: if isApprovedMarketplaceItem() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /creatorSubmissions/{id} {
      allow read: if isAdmin() || isOwner('creatorId');
      allow create: if isCreator() && isCreateOwner('creatorId');
      allow update, delete: if isAdmin();
    }

    match /exportJobs/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow create: if isCreateOwner('userId');
      allow update, delete: if isAdmin();
    }

    match /userContentEntitlements/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow write: if isAdmin();
    }

    match /userEntitlements/{id} {
      allow read, write: if false;
    }

    match /contentLicenses/{id} {
      allow read: if isAdmin() || isOwner('licenseeId');
      allow write: if isAdmin();
    }

    match /consentRecords/{id} {
      allow read: if isAdmin() || isOwner('userId');
      allow create: if isCreateOwner('userId');
      allow update: if isAdmin() || isOwner('userId');
      allow delete: if isAdmin();
    }

    match /provenanceRecords/{id} {
      allow read, write: if isAdmin();
    }

    match /analyticsEvents/{id} {
      allow create: if validAnalyticsCreate();
      allow read, update, delete: if isAdmin();
    }

    match /tierConfigs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roadmapPhases/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /expansionModules/{id} {
      allow read: if resource.data.publicVisibility == 'public' || isAdmin();
      allow write: if isAdmin();
    }

    match /systemIntegrations/{id} {
      allow read, write: if isAdmin();
    }

    match /seoPages/{id} {
      allow read: if (resource.data.status == 'published' && resource.data.noIndex == false) || isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
