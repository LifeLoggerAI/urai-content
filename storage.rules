rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn()
        && (
          request.auth.token.role == role
          || (request.auth.token.roles is list && role in request.auth.token.roles)
        );
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('internalAdmin');
    }

    function isCreator() {
      return hasRole('creator') || hasRole('studio') || isAdmin();
    }

    function isAllowedCreatorContentType() {
      return request.resource.contentType.matches('image/(png|jpeg|webp|gif)')
        || request.resource.contentType.matches('audio/(mpeg|wav|ogg|mp4)')
        || request.resource.contentType.matches('video/(mp4|webm)')
        || request.resource.contentType in [
          'text/plain',
          'application/json',
          'application/pdf',
          'model/gltf+json',
          'model/gltf-binary'
        ];
    }

    function validCreatorUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 25 * 1024 * 1024
        && request.resource.contentType is string
        && isAllowedCreatorContentType();
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /creator-submissions/{creatorId}/{allPaths=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == creatorId);
      allow create, update: if isCreator()
        && request.auth.uid == creatorId
        && validCreatorUpload();
      allow delete: if isCreator() && request.auth.uid == creatorId;
    }

    match /exports/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /licenses/{licenseeId}/{allPaths=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == licenseeId);
      allow write: if isAdmin();
    }

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
